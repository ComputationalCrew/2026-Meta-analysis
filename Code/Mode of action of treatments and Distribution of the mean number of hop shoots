# Upload the raw data

downy <- read.csv(".../Downy Mildew Fungicide Meta Analysis Database_Github.csv", check.names=FALSE)

# Data manipulation
downy  <- downy  %>%
  mutate(MOA = ifelse(MOA %in% c("BM01", "BM02"), "BM", MOA))

# Table 1. Mode of action of treatments 
# Get count of number of plots that evaluated a given MOA in each state
dm_count <- downy %>%
  group_by(MOA, State) %>%
  summarise(count = n())

qpvt(downy, c("MOA", "State"), "Trial", "n()")

# Figure 1 Distribution of the mean number of hop shoots 

ggplot(downy, aes(x = Spikes, fill = Treat))+
  geom_histogram(alpha = 0.5, position = "identity") +
  labs(x = "Spikes per plant", y = "Frequency") +
  theme_classic() +
  coord_cartesian(xlim = c(0, 200), ylim = c(0, 800))

ggplot(downy, aes(x = tResponse_ratio, fill = Treat)) +
  geom_histogram(alpha = 0.5, position = "identity") +
  labs(x = "Response ratio", y = "Frequency") +
  theme_classic() +
  coord_cartesian(xlim = c(-6, 1.5), ylim = c(0, 200))

